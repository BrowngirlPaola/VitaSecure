# Secrets & env (Directives §4.10.3 — never commit)
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Frontend runtime config (holds the project's public keys) — copy from env.example.js
frontend/js/env.js

# Dependencies / build output
node_modules/
dist/
build/
.cache/

# Blockchain artefacts (regenerated by deploy)
blockchain/artifacts/
blockchain/cache/
blockchain/typechain-types/

# Supabase local
supabase/.branches/
supabase/.temp/

# Editor / OS
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/

# Logs
*.log
npm-debug.log*
