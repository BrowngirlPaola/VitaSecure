# =============================================================================
# VitaSecure / secure-ehr — environment template (Directives §4.1, §6)
# Copy to .env and fill in. NEVER commit real values. Secrets that must stay
# server-side go into Supabase secrets, NOT here and NOT in the frontend.
# =============================================================================

# ---- Frontend (PUBLIC keys only) -------------------------------------------
# Surfaced to the browser via window.__ENV__ / js/config.js.
# Auth is Supabase Auth (email/password) — no Clerk keys.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional override; defaults to ${SUPABASE_URL}/functions/v1
FUNCTIONS_URL=

# ---- Supabase Edge Function secrets (set via `supabase secrets set`) --------
# Listed here for reference ONLY — do not load these into the frontend.
# AES_KEY=                 # AES-256-GCM key for clinical fields (server-only)
# CHAIN_RPC_URL=           # Permissioned EVM RPC endpoint
# ANCHOR_SIGNER_KEY=       # Blockchain private key for anchoring (server-only)
# RBAC_CONTRACT_ADDRESS=   # From blockchain/deployments/addresses.json
# ANCHOR_CONTRACT_ADDRESS= # From blockchain/deployments/addresses.json
# (Token verification uses the Supabase JWT secret / JWKS — no Clerk JWKS.)

# ---- Blockchain (blockchain/.env) ------------------------------------------
# RPC_URL=
# DEPLOYER_PRIVATE_KEY=    # Dev key only — never a real key
